# Build-time defines for the mobile app, passed with:
#
#   flutter run --dart-define-from-file=.env
#   flutter build apk --release --dart-define-from-file=.env
#
# Copy to mobile/.env (gitignored) and fill in. Same convention as
# backend/.env: absence of a key selects the keyless/no-op provider —
# dev builds typically leave everything but GOOGLE_SERVER_CLIENT_ID unset.
# Release/tbd/prd builds get this file materialized from the secrets
# manager by CI, never committed.

# Google OAuth web ("server") client ID. Audience of the minted ID token;
# must equal the backend's GOOGLE_CLIENT_ID or sign-in 401s. The Google
# button is hidden while unset.
# GOOGLE_SERVER_CLIENT_ID=...apps.googleusercontent.com

# Sentry crash reporting. Unset = no-op reporter, nothing leaves the device.
# SENTRY_DSN=https://...ingest.sentry.io/...
# SENTRY_ENVIRONMENT=tbd

# PostHog analytics. Unset = debug sink (events logged to console only).
# POSTHOG_API_KEY=phc_...
# Ingestion host; defaults to https://us.i.posthog.com — set for EU/self-host.
# POSTHOG_HOST=https://eu.i.posthog.com

# Comma-separated features to turn OFF. Known names: apple_login, google_login.
# Mirrors the backend's DISABLED_FEATURES so one runbook covers both sides.
# DISABLED_FEATURES=apple_login,google_login
