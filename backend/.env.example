# Drape backend — environment configuration template.
#
# .env is GITIGNORED in every environment because it contains secrets.
# This file (.env.example) is the canonical list of every key the app reads —
# copy it to .env and fill in real values:
#
#   cp .env.example .env
#
#   - dev:       developer fills .env locally.
#   - tbd / prd: deploy infra (CI/CD job, ECS entrypoint, Secrets Manager sidecar)
#                materializes .env on the container before the app starts.
#
# The Docker image itself never ships secrets.

# ---- Required ----

# One of: dev | tbd | prd. Default: dev.
# `dev`        -> log-only email, OAuth routes not mounted, local AES encryptor.
# `tbd`/`prd`  -> SES, Apple/Google OAuth verification, KMS envelope encryption.
ENVIRONMENT=dev

# Postgres connection string. Each env points at its own physical database.
#   dev: matches docker-compose.yml (host port 5433 to avoid conflicts).
#   tbd: postgresql+psycopg2://USER:PASS@HOST:5432/drape_tbd
#   prd: postgresql+psycopg2://USER:PASS@HOST:5432/drape_prd
DATABASE_URL=postgresql+psycopg2://admin:password@localhost:5433/drape

# ---- Feature switches ----

# Comma-separated features to turn OFF. Known names: apple_login, google_login,
# billing, push (unknown names refuse to boot). A disabled feature's config keys
# below are NOT required in tbd/prd; its endpoints answer 400
# (oauth_unavailable / billing_unavailable), and disabled push makes the
# notify_user fan-out a logged no-op (device registration keeps working).
# Read once at boot — flipping it means restart (redeploy in tbd/prd).
# DISABLED_FEATURES=apple_login,google_login,billing,push

# ---- JWT (own-issued access tokens) ----

# Override in tbd/prd — startup will refuse to boot if the dev default is used there.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=dev-only-do-not-use-in-tbd-or-prd-min-32-bytes
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# ---- Required when ENVIRONMENT=tbd or prd ----

# Apple Sign-In — CLIENT_ID is the token audience; comma-separate if both the
# bundle ID (native flow) and Service ID (web/Android flow) are in play.
# APPLE_CLIENT_ID=com.drape.app
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY_PATH=/run/secrets/apple_private_key.p8

# Google Sign-In — comma-separate the iOS and Android OAuth client IDs
# (each platform's tokens carry their own client ID as audience).
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# AWS SES (transactional email)
# SES_REGION=ca-central-1
# SES_FROM_ADDRESS=no-reply@drape.app
# Mobile handles this via the drape:// custom scheme (App/Universal Links = prod).
PASSWORD_RESET_URL_TEMPLATE=drape://drape.app/auth/reset-password?token={token}

# Stripe (billing; dev uses MockPaymentProvider). Webhook endpoint:
# POST /api/v1/billing/webhook/stripe — subscribe it to invoice.paid,
# invoice.payment_failed, customer.subscription.deleted.
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO_MONTHLY=price_...
# STRIPE_PRICE_ID_PRO_YEARLY=price_...
# Portal return target; defaults to the drape:// deep link.
# STRIPE_PORTAL_RETURN_URL=drape://drape.app/billing

# Firebase Cloud Messaging (push; dev logs via LogPushProvider). The full
# service-account JSON, raw or base64-encoded — base64 survives the one-line
# .env format. Upload the APNS .p8 key to the Firebase project settings so
# FCM relays iOS deliveries to APNS.
# FCM_CREDENTIALS_JSON=eyJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsIC4uLn0=

# Anthropic (AI styling)
# ANTHROPIC_API_KEY=sk-ant-...

# AWS KMS (envelope encryption for measurements)
# KMS_KEY_ID=arn:aws:kms:ca-central-1:...:key/...
AWS_REGION=ca-central-1

# AWS S3 bucket for wardrobe / avatar / outfit images (Phase 5e — required in tbd/prd).
# IMAGE_BUCKET=drape-images-tbd

# Optional CloudFront base URL for image delivery in tbd/prd. When set,
# S3ImageStorage returns https://{cdn}/{key}; when unset, falls back to the S3
# virtual-hosted URL (requires the bucket to be publicly readable).
# IMAGE_CDN_BASE_URL=https://cdn.drape.app

# ---- Required in dev ----

# Dev image storage (LocalFsStorage). Files land in `LOCAL_IMAGE_DIR` and are
# served back at `LOCAL_IMAGE_BASE_URL` via FastAPI's StaticFiles mount.
# Override LOCAL_IMAGE_BASE_URL when the API isn't running on localhost:8000.
LOCAL_IMAGE_DIR=uploads
LOCAL_IMAGE_BASE_URL=http://localhost:8000/uploads

# 32-byte base64 key used by LocalAesEncryptor when ENVIRONMENT=dev.
# Generate your OWN per-developer key (do NOT reuse this example value):
#   python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# Required since Phase 5b — without it the API refuses to start.
MEASUREMENT_DEK_DEV=replace-with-your-own-32-byte-base64-dek
